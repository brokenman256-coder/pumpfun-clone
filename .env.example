VITE_SOLANA_CLUSTER=devnet
VITE_SOLANA_RPC=https://api.devnet.solana.com
# Treasury — receives Phantom buy SOL (and create fees)
VITE_FEE_RECIPIENT=YourSolanaWalletPublicKeyHere
VITE_ADMIN_KEY=change-me-strong-admin-key
# Deployed launchpad program (see program/README.md to build/deploy your own)
VITE_LAUNCHPAD_PROGRAM_ID=AXgGrZTKV2FJWuVAaj5z36TNGWjJHLQwSkPSh5aLfsg8
# Public address only (never the secret key) of the bot / payout wallet
VITE_BOT_WALLET_ADDRESS=

# ── Server-only (Vercel env, NOT VITE_) ────────────────────────────────
# Base58 secret key for managed sell payouts (api/managed-sell.js).
# Fund this wallet with SOL so sells can pay traders automatically.
# BOT_WALLET_SECRET=
# Optional RPC override for the payout function:
# SOLANA_RPC=
# SOLANA_CLUSTER=devnet
