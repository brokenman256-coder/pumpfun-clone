# Managed market + free bots (default). Traders use Phantom for real SOL.
VITE_PERSONAL_MODE=true
VITE_PERSONAL_START_SOL=100

# Real Solana cluster for Phantom trades
VITE_SOLANA_CLUSTER=devnet
# mainnet-beta when you go live:
# VITE_SOLANA_CLUSTER=mainnet-beta
VITE_SOLANA_RPC=https://api.devnet.solana.com

# Treasury public key — receives real buy SOL from traders
VITE_FEE_RECIPIENT=YourPhantomTreasuryPublicKey

VITE_ADMIN_KEY=change-me-strong-admin-key

# Optional on-chain program
# VITE_LAUNCHPAD_PROGRAM_ID=
# VITE_BOT_WALLET_ADDRESS=

# ── Vercel server-only (NOT VITE_) ───────────────────────────────────
# Funded wallet that pays traders on sell (base58 secret):
# BOT_WALLET_SECRET=
# GITHUB_TOKEN=   # optional durable live-board
